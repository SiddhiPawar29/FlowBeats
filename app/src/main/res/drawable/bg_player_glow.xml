<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D0A1A"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="60%"
                android:centerX="0.5"
                android:centerY="0.38"
                android:startColor="#331A0A3D"
                android:endColor="#000D0A1A"/>
        </shape>
    </item>
</layer-list>
