<?xml version="1.0" encoding="utf-8"?>
<resources>



    <!-- TEXT APPEARANCES -->


    <!-- CARD STYLES -->


    <style name="Card.Glass.Elevated" parent="Card.Glass">
        <item name="cardElevation">@dimen/elevation_xl</item>
        <item name="strokeColor">@color/glass_border_bright</item>
    </style>

    <!-- BUTTON STYLES -->


    <style name="Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/electric_purple</item>
        <item name="strokeColor">@color/electric_purple</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">@dimen/radius_circle</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="rippleColor">@color/ripple_color</item>
    </style>

    <!-- TEXT INPUT STYLE -->




    <!-- DIALOG STYLE -->
    <style name="Dialog.FlowBeats" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_card</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.FlowBeats.Dialog</item>
    </style>

    <style name="ShapeAppearance.FlowBeats.Dialog" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Legacy text styles for backward compat -->


</resources>
