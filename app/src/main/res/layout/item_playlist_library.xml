<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/glass_background"
    app:strokeWidth="1dp"
    app:strokeColor="@color/glass_border"
    android:foreground="@drawable/ripple_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Playlist Cover Art -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPlaylistCoverLib"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivPlaylistCoverLib"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_album_art_placeholder"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Playlist Name -->
        <TextView
            android:id="@+id/tvPlaylistNameLib"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Playlist Name"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/cardPlaylistCoverLib"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/cardPlaylistCoverLib"
            app:layout_constraintBottom_toTopOf="@id/tvSongCountLib"/>

        <!-- Song count -->
        <TextView
            android:id="@+id/tvSongCountLib"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="12 songs"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/cardPlaylistCoverLib"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPlaylistNameLib"
            app:layout_constraintBottom_toBottomOf="@id/cardPlaylistCoverLib"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
