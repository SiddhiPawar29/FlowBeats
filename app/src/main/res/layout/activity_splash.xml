<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash"
    android:fitsSystemWindows="true">

    <!-- Glow orb top -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_album_placeholder"
        android:alpha="0.08"
        android:translationX="-80dp"
        android:translationY="-80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Glow orb bottom -->
    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/bg_album_placeholder"
        android:alpha="0.06"
        android:translationX="80dp"
        android:translationY="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Logo + Text Container -->
    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42">

        <!-- Vinyl Logo Circle with glow ring -->
        <FrameLayout
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_gravity="center">

            <!-- Outer glow ring -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_album_placeholder"
                android:alpha="0.3"/>

            <!-- Logo disk -->
            <View
                android:id="@+id/logoCircle"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_album_placeholder"
                android:elevation="8dp"/>

        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:id="@+id/tvAppNameSplash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="FlowBeats"
            android:textColor="@color/text_primary"
            android:textSize="40sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:fontFamily="sans-serif-black"/>

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Feel the Flow"
            android:textColor="@color/text_tertiary"
            android:textSize="16sp"
            android:letterSpacing="0.12"
            android:fontFamily="sans-serif-light"/>

    </LinearLayout>

    <!-- Loading bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="@color/electric_purple"
        android:alpha="0"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
