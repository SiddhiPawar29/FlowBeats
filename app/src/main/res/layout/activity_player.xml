<?xml version="1.0" encoding="utf-8"?>
<!-- This is the full-screen Now Playing activity opened when you tap the mini player -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_player_glow"
    android:fitsSystemWindows="true">

    <!-- Top Controls Row -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_glass_card"
            android:tint="@color/text_primary"
            android:padding="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Now Playing"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.06"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintEnd_toStartOf="@id/btnMore"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"/>

        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_more"
            android:background="@drawable/bg_glass_card"
            android:tint="@color/text_primary"
            android:padding="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Vinyl Disk Container (rotates when playing) -->
    <FrameLayout
        android:id="@+id/diskWrapper"
        android:layout_width="@dimen/disk_size"
        android:layout_height="@dimen/disk_size"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Outer glow ring (does NOT rotate) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_album_placeholder"
            android:alpha="0.12"/>

        <!-- Vinyl disk that rotates -->
        <FrameLayout
            android:id="@+id/vinylDisk"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center">

            <!-- Vinyl grooves -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_vinyl_disk"/>

            <!-- Album art clipped to circle in center -->
            <ImageView
                android:id="@+id/ivAlbumArt"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_album_art_placeholder"
                android:clipToOutline="true"
                android:background="@drawable/bg_album_placeholder"/>

        </FrameLayout>

        <!-- Needle arm overlay (optional visual detail) -->
        <View
            android:layout_width="6dp"
            android:layout_height="90dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="20dp"
            android:background="#AA7C3AED"
            android:rotation="30"/>

    </FrameLayout>

    <!-- Song Info -->
    <LinearLayout
        android:id="@+id/songInfoBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/diskWrapper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvSongName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Song Title"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvArtistName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Unknown Artist"
                android:textColor="@color/text_tertiary"
                android:textSize="15sp"/>



        </LinearLayout>
    </LinearLayout>

    <!-- SeekBar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/seekBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="28dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/songInfoBlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/electric_purple"
            android:progressBackgroundTint="@color/glass_border"
            android:thumb="@drawable/seekbar_thumb"
            android:max="100"
            android:progress="35"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1:24"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/seekBar"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4:02"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/seekBar"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Playback Controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/controlsBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="28dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/seekBlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Shuffle -->
        <ImageButton
            android:id="@+id/btnShuffle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_shuffle"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_tertiary"
            android:padding="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Previous -->
        <ImageButton
            android:id="@+id/btnPrevious"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:src="@drawable/ic_skip_previous"
            android:tint="@color/text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnPlayPause"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="16dp" />

        <!-- Play/Pause (large center button) -->
        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="@drawable/bg_button_rounded"
            android:elevation="8dp"
            android:padding="16dp"
            android:src="@drawable/ic_pause"
            android:tint="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnNext"
            app:layout_constraintStart_toEndOf="@id/btnPrevious"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Next -->
        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:src="@drawable/ic_skip_next"
            android:tint="@color/text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnPlayPause"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="16dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    <!-- Gesture Camera Preview (bottom-right, floating) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="80dp"
        android:layout_height="106dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:foreground="@drawable/bg_camera_border"
        android:clipToOutline="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Gesture indicator -->
    <TextView
        android:id="@+id/tvGestureIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_gesture_pill"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/cameraPreview"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
