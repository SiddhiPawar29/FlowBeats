<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    app:cardCornerRadius="16dp"
    app:cardElevation="@dimen/elevation_sm"
    app:cardBackgroundColor="@color/background_card"
    app:strokeWidth="1dp"
    app:strokeColor="@color/glass_border"
    android:foreground="@drawable/ripple_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md">

        <!-- Album Art -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/ivSongAlbumArt"
            android:layout_width="@dimen/album_art_sm"
            android:layout_height="@dimen/album_art_sm"
            app:cardCornerRadius="12dp"
            app:cardElevation="@dimen/elevation_sm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/albumArt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_album_art_placeholder" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Song Info -->
        <LinearLayout
            android:id="@+id/songInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_md"
            app:layout_constraintStart_toEndOf="@id/ivSongAlbumArt"
            app:layout_constraintEnd_toStartOf="@id/tvDuration"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvSongName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aasman_Ko_Chukar_Dekh"
                android:textAppearance="@style/TextAppearance.FlowBeats.Body"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvSongArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/unknown_artist"
                android:textAppearance="@style/TextAppearance.FlowBeats.Subtitle"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Duration -->
        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:20"
            android:textAppearance="@style/TextAppearance.FlowBeats.Subtitle"
            android:layout_marginEnd="@dimen/spacing_sm"
            app:layout_constraintEnd_toStartOf="@id/btnMore"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- More Button -->
        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="@dimen/icon_size_lg"
            android:layout_height="@dimen/icon_size_lg"
            android:src="@drawable/ic_more"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:padding="@dimen/spacing_xs"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
